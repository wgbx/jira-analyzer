{
  "name": "jira-analyzer",
  "version": "1.0.0",
  "private": true,
  "description": "分析 Jira 父任务子项列表，生成可筛选的 HTML 报告",
  "scripts": {
    "setup": "python3 -m pip install -r requirements.txt && npm run git:local-ignore",
    "git:local-ignore": "bash scripts/setup-local-git.sh",
    "start": "python3 jira_analyzer.py",
    "analyze": "python3 jira_analyzer.py",
    "serve": "python3 scripts/serve.py",
    "dev": "python3 scripts/serve.py --watch",
    "migrate": "python3 scripts/jira-item-migrate.py"
  },
  "engines": {
    "node": ">=18"
  }
}
