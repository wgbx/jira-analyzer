{
  "jira": {
    "base_url": "https://your-domain.atlassian.net",
    "email": "your-email@example.com",
    "api_token": "YOUR_JIRA_API_TOKEN_HERE"
  },
  "parent_issue": "KAT-11542",
  "assignee": "your name",
  "output": {
    "format": "html",
    "path": "output/jira-report.html"
  },
  "filters": {
    "subtasks_scope": "all",
    "active_statuses": ["待办", "正在进行"],
    "exclude_keywords": [
      "(Done)",
      "(done)",
      "(Backlog)",
      "(backlog)",
      "(Invalid)",
      "(invalid)",
      "(Moved)",
      "(moved)"
    ]
  },
  "scheduled": {
    "path": "data/scheduled.json"
  },
  "watch": {
    "refresh_interval_seconds": 120
  }
}